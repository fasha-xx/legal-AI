---
const categories = [
  '全部',
  '政策法规',
  '司法动态',
  '知识产权',
  'AI 与数据合规',
  '企业合规',
  '法律科技',
  '监管动态',
  '其他',
];
---

<div class="mb-6 space-y-4">
  <div class="relative">
    <input
      type="text"
      id="news-search"
      placeholder="搜索资讯标题、摘要或标签..."
      class="w-full px-4 py-2.5 pl-10 text-sm border border-gray-200 rounded-lg focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 transition-colors"
    />
    <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
  </div>

  <div class="overflow-x-auto">
    <div class="flex gap-2 min-w-max pb-2">
      {categories.map((cat, i) => (
        <button
          data-category={cat}
          class:list={[
            'category-btn px-3 py-1.5 text-sm rounded-full border transition-colors whitespace-nowrap',
            i === 0
              ? 'bg-primary text-white border-primary'
              : 'bg-white text-secondary border-gray-200 hover:border-primary hover:text-primary',
          ]}
        >
          {cat}
        </button>
      ))}
    </div>
  </div>
</div>
