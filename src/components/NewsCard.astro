---
interface Props {
  title: string;
  summary: string;
  source: string;
  date: string;
  category: string;
  level: string;
  url: string;
}

const { title, summary, source, date, category, level, url } = Astro.props;

const categoryColors: Record<string, string> = {
  '法律法规': 'bg-blue-100 text-blue-700',
  '司法案例': 'bg-purple-100 text-purple-700',
  '知识产权': 'bg-green-100 text-green-700',
  'AI 合规': 'bg-orange-100 text-orange-700',
  '数据合规': 'bg-cyan-100 text-cyan-700',
  '企业合规': 'bg-indigo-100 text-indigo-700',
  '监管政策': 'bg-red-100 text-red-700',
  '法律科技': 'bg-teal-100 text-teal-700',
  '律师行业': 'bg-gray-100 text-gray-700',
};

const catClass = categoryColors[category] || 'bg-gray-100 text-gray-700';
---

<article class="bg-white border border-gray-200 rounded-lg p-5 hover:shadow-md transition-shadow">
  <div class="flex items-center gap-2 mb-3">
    <span class={`text-xs px-2 py-0.5 rounded-full ${catClass}`}>{category}</span>
    {level === '重点' && (
      <span class="text-xs px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-medium">重点</span>
    )}
  </div>
  <h3 class="text-base font-semibold text-gray-900 mb-2 leading-snug">{title}</h3>
  <p class="text-sm text-secondary mb-3 line-clamp-3">{summary}</p>
  <div class="flex items-center justify-between">
    <span class="text-xs text-gray-400">{source} · {date}</span>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-primary hover:text-primary-light transition-colors"
    >
      阅读原文 &rarr;
    </a>
  </div>
</article>
