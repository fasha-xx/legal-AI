---
import newsData from '../data/daily-news.json';

interface NewsItem {
  id: string;
  title: string;
  summary: string;
  source: string;
  date: string;
  category: string;
  level: string;
  url: string;
}

const news: NewsItem[] = newsData;

// 获取最新日期的重点资讯，最多3条
const dates = [...new Set(news.map(n => n.date))].sort((a, b) => b.localeCompare(a));
const latestDate = dates[0];
const highlights = news
  .filter(n => n.date === latestDate && n.level === '重点')
  .slice(0, 3);
---

{highlights.length > 0 && (
  <section class="mb-8">
    <h2 class="text-lg font-semibold text-primary mb-3">今日重点</h2>
    <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
      <ol class="space-y-2">
        {highlights.map((item, i) => (
          <li class="flex items-start gap-2">
            <span class="inline-flex items-center justify-center w-5 h-5 rounded-full bg-amber-500 text-white text-xs font-medium flex-shrink-0 mt-0.5">
              {i + 1}
            </span>
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-gray-800 hover:text-primary transition-colors"
            >
              {item.title}
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>
)}
