---
interface Props {
  name: string;
  url: string;
  category: string;
  description: string;
  official: boolean;
  pricing: string;
  recommended: boolean;
}

const { name, url, category, description, official, pricing } = Astro.props;

const pricingLabel: Record<string, { text: string; cls: string }> = {
  free: { text: '免费', cls: 'bg-green-50 text-green-700' },
  paid: { text: '付费', cls: 'bg-amber-50 text-amber-700' },
  partial: { text: '部分付费', cls: 'bg-amber-50 text-amber-700' },
  unknown: { text: '', cls: '' },
};
const p = pricingLabel[pricing] || pricingLabel.unknown;
---

<div class="bg-white rounded-lg border border-gray-100 p-4 hover:shadow-md transition-shadow">
  <!-- Row 1: Title + Button -->
  <div class="flex items-start justify-between gap-3">
    <h3 class="font-bold text-primary text-sm leading-snug line-clamp-2 flex-1 min-w-0">{name}</h3>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="shrink-0 text-xs bg-primary text-white px-3 py-1.5 rounded hover:bg-primary-light transition-colors"
    >访问</a>
  </div>
  <!-- Row 2: Badges -->
  <div class="flex items-center gap-1.5 mt-1.5">
    {official && <span class="text-[10px] bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">官方</span>}
    {p.text && <span class:list={['text-[10px] px-1.5 py-0.5 rounded', p.cls]}>{p.text}</span>}
  </div>
  <!-- Row 3: Description -->
  <p class="text-xs text-gray-600 line-clamp-2 leading-relaxed mt-1.5">{description}</p>
  <!-- Row 4: Category -->
  <p class="text-[11px] text-gray-400 mt-2">{category}</p>
</div>
