---
interface Props {
  name: string;
  url: string;
  category: string;
  description: string;
  tags: string[];
  official: boolean;
  free: boolean;
}

const { name, url, category, description, tags, official, free } = Astro.props;
---

<div class="bg-white rounded-lg border border-gray-100 p-5 hover:shadow-md transition-shadow">
  <div class="flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <h3 class="font-semibold text-primary truncate">{name}</h3>
        {official && (
          <span class="shrink-0 text-xs bg-blue-50 text-blue-700 px-1.5 py-0.5 rounded">官方</span>
        )}
      </div>
      <span class="text-xs text-secondary">{category}</span>
      <p class="text-sm text-gray-600 mt-2 line-clamp-2">{description}</p>
      <div class="flex flex-wrap gap-1.5 mt-3">
        {tags.map(tag => (
          <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{tag}</span>
        ))}
        {!free && (
          <span class="text-xs bg-amber-50 text-amber-700 px-2 py-0.5 rounded">付费</span>
        )}
      </div>
    </div>
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="shrink-0 mt-1 text-sm bg-primary text-white px-4 py-1.5 rounded-md hover:bg-primary-light transition-colors"
    >访问</a>
  </div>
</div>
