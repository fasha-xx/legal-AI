---
import Layout from '../layouts/Layout.astro';
import TodayHighlights from '../components/TodayHighlights.astro';
import NewsCategoryFilter from '../components/NewsCategoryFilter.astro';
import NewsCard from '../components/NewsCard.astro';
import newsData from '../data/daily-news.json';

interface NewsItem {
  id: string;
  title: string;
  summary: string;
  source: string;
  date: string;
  category: string;
  level: string;
  url: string;
}

const news: NewsItem[] = newsData;

// 按日期倒序分组
const dateGroups = news.reduce<Record<string, NewsItem[]>>((acc, item) => {
  if (!acc[item.date]) acc[item.date] = [];
  acc[item.date].push(item);
  return acc;
}, {});

const sortedDates = Object.keys(dateGroups).sort((a, b) => b.localeCompare(a));
---

<Layout
  title="每日资讯｜法律实务与 AI 技能库"
  description="聚合每日值得关注的法律法规、司法案例、知识产权、AI 合规、数据合规、企业合规与法律科技动态。"
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8">
      <h1 class="text-2xl sm:text-3xl font-bold text-primary">每日资讯</h1>
      <p class="mt-2 text-secondary">
        聚合每日值得关注的法律、知识产权、AI 合规与法律科技动态。
      </p>
    </div>

    <TodayHighlights />

    <NewsCategoryFilter />

    <div id="news-list">
      {sortedDates.map(date => (
        <div class="news-date-group mb-8" data-date={date}>
          <h2 class="text-sm font-medium text-gray-400 mb-3 border-b border-gray-100 pb-2">{date}</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {dateGroups[date].map(item => (
              <div class="news-item" data-category={item.category}>
                <NewsCard
                  title={item.title}
                  summary={item.summary}
                  source={item.source}
                  date={item.date}
                  category={item.category}
                  level={item.level}
                  url={item.url}
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-6 border-t border-gray-100">
      <p class="text-xs text-gray-400">
        本页面内容为站长基于公开信息整理的资讯摘要，仅供学习、研究和实务参考，不构成法律意见或投资建议。具体事项请以官方发布内容为准。
      </p>
    </div>
  </section>
</Layout>

<script>
  // 分类筛选逻辑
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
    const items = document.querySelectorAll<HTMLElement>('.news-item');
    const groups = document.querySelectorAll<HTMLElement>('.news-date-group');

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset.category || '全部';

        // 更新按钮样式
        buttons.forEach(b => {
          b.classList.remove('bg-primary', 'text-white', 'border-primary');
          b.classList.add('bg-white', 'text-secondary', 'border-gray-200');
        });
        btn.classList.remove('bg-white', 'text-secondary', 'border-gray-200');
        btn.classList.add('bg-primary', 'text-white', 'border-primary');

        // 筛选资讯
        items.forEach(item => {
          if (cat === '全部' || item.dataset.category === cat) {
            item.style.display = '';
          } else {
            item.style.display = 'none';
          }
        });

        // 隐藏空日期组
        groups.forEach(group => {
          const visibleItems = group.querySelectorAll('.news-item:not([style*="display: none"])');
          group.style.display = visibleItems.length > 0 ? '' : 'none';
        });
      });
    });
  });
</script>
