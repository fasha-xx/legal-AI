---
import Layout from '../layouts/Layout.astro';
import TodayHighlights from '../components/TodayHighlights.astro';
import NewsCategoryFilter from '../components/NewsCategoryFilter.astro';
import NewsCard from '../components/NewsCard.astro';
import newsData from '../data/daily-news.json';

const news: any[] = newsData;

const dateGroups = news.reduce<Record<string, any[]>>((acc, item) => {
  if (!acc[item.date]) acc[item.date] = [];
  acc[item.date].push(item);
  return acc;
}, {});

const sortedDates = Object.keys(dateGroups).sort((a, b) => b.localeCompare(a));
---

<Layout
  title="每日资讯｜法律实务与 AI 技能库"
  description="聚合每日值得关注的法律法规、司法案例、知识产权、AI 合规与法律科技动态。"
>
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
    <div class="mb-8">
      <h1 class="text-2xl sm:text-3xl font-bold text-primary">每日资讯</h1>
      <p class="mt-2 text-secondary">
        每日自动聚合法律、政策、知识产权、AI 合规与法律科技相关资讯，并生成面向律师实务的简要摘要。内容由自动化工具整理，仅供学习和研究参考。
      </p>
    </div>

    <TodayHighlights />
    <NewsCategoryFilter />

    <div id="news-list">
      {sortedDates.map(date => (
        <div class="news-date-group mb-8" data-date={date}>
          <h2 class="text-sm font-medium text-gray-400 mb-3 border-b border-gray-100 pb-2">{date}</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            {dateGroups[date].map(item => (
              <div class="news-item" data-category={item.category} data-title={item.title} data-summary={item.summary || ''} data-tags={(item.tags || []).join(',')}>
                <NewsCard
                  title={item.title}
                  summary={item.summary || ''}
                  legalPoint={item.legalPoint || ''}
                  source={item.source}
                  date={item.date}
                  category={item.category}
                  tags={item.tags || []}
                  url={item.url}
                />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-6 border-t border-gray-100">
      <p class="text-xs text-gray-400">
        本站每日资讯仅对公开信息进行标题索引和简要摘要整理，原文版权归原发布机构所有。本站内容仅供学习、研究和实务参考，不构成法律意见。如需了解完整内容，请访问原文链接。
      </p>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.category-btn');
    const items = document.querySelectorAll<HTMLElement>('.news-item');
    const groups = document.querySelectorAll<HTMLElement>('.news-date-group');
    const searchInput = document.getElementById('news-search') as HTMLInputElement | null;

    let activeCategory = '全部';
    let searchQuery = '';

    function applyFilters() {
      const q = searchQuery.toLowerCase();
      items.forEach(item => {
        const catMatch = activeCategory === '全部' || item.dataset.category === activeCategory;
        const searchMatch = !q ||
          (item.dataset.title || '').toLowerCase().includes(q) ||
          (item.dataset.summary || '').toLowerCase().includes(q) ||
          (item.dataset.tags || '').toLowerCase().includes(q);
        item.style.display = catMatch && searchMatch ? '' : 'none';
      });
      groups.forEach(group => {
        const visible = group.querySelectorAll('.news-item:not([style*="display: none"])');
        group.style.display = visible.length > 0 ? '' : 'none';
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.category || '全部';
        buttons.forEach(b => {
          b.classList.remove('bg-primary', 'text-white', 'border-primary');
          b.classList.add('bg-white', 'text-secondary', 'border-gray-200');
        });
        btn.classList.remove('bg-white', 'text-secondary', 'border-gray-200');
        btn.classList.add('bg-primary', 'text-white', 'border-primary');
        applyFilters();
      });
    });

    searchInput?.addEventListener('input', () => {
      searchQuery = searchInput.value.trim();
      applyFilters();
    });
  });
</script>
