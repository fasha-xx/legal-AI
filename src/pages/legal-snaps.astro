---
import Layout from '../layouts/Layout.astro';
import LegalSnapAlbumCard from '../components/LegalSnapAlbumCard.astro';
import legalSnaps from '../data/legal-snaps.json';

const items = legalSnaps || [];
const categories = ['全部', ...Array.from(new Set(items.map((item) => item.category).filter(Boolean)))];
---

<Layout title="法图摘录 - 法律实务与 AI 技能库">
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <header class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">
        法图摘录
      </h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600">
        收集法律、法规、政策、案例规则等图卡化内容，方便阅读、收藏和传播。
      </p>
    </header>

    <div class="mb-8 space-y-4">
      <input
        id="legal-snaps-search"
        type="search"
        placeholder="搜索图集标题、说明、标签..."
        class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none focus:border-blue-500"
      />

      <div class="flex flex-wrap gap-2">
        {categories.map((category) => (
          <button
            type="button"
            class="rounded-full bg-slate-100 px-4 py-2 text-sm text-slate-600 hover:bg-blue-50 hover:text-blue-700"
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>
    </div>

    {items.length === 0 ? (
      <div class="rounded-2xl border border-dashed border-slate-300 bg-white p-8 text-center text-sm text-slate-500">
        暂无法图摘录内容，后续将持续更新。
      </div>
    ) : (
      <div id="legal-snaps-grid" class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
        {items.map((item) => (
          <div
            data-card
            data-title={item.title}
            data-description={item.description || ''}
            data-category={item.category}
            data-tags={(item.tags || []).join(' ')}
          >
            <LegalSnapAlbumCard item={item} />
          </div>
        ))}
      </div>
    )}

    <!-- Disclaimer -->
    <div class="mt-12 rounded-xl bg-slate-50 p-6 text-sm text-slate-500">
      <p class="font-medium text-slate-700 mb-2">免责声明</p>
      <p>
        本站"法图摘录"用于对公开法律、法规、政策及案例规则进行图卡化整理，内容仅供学习、研究和实务参考，不构成正式法律意见。如需引用或适用，请以官方原文及正式法律文件为准。
      </p>
    </div>
  </section>

  <script>
    const searchInput = document.getElementById('legal-snaps-search') as HTMLInputElement;
    const buttons = document.querySelectorAll('[data-category]');
    const cards = document.querySelectorAll('[data-card]');

    let activeCategory = '全部';

    function filterCards() {
      const keyword = (searchInput?.value || '').toLowerCase().trim();

      cards.forEach((card) => {
        const title = card.getAttribute('data-title') || '';
        const description = card.getAttribute('data-description') || '';
        const category = card.getAttribute('data-category') || '';
        const tags = card.getAttribute('data-tags') || '';

        const text = `${title} ${description} ${category} ${tags}`.toLowerCase();

        const matchKeyword = !keyword || text.includes(keyword);
        const matchCategory = activeCategory === '全部' || category === activeCategory;

        (card as HTMLElement).style.display = matchKeyword && matchCategory ? '' : 'none';
      });
    }

    searchInput?.addEventListener('input', filterCards);

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        activeCategory = button.getAttribute('data-category') || '全部';
        
        // Update active button style
        buttons.forEach((b) => {
          b.classList.remove('bg-blue-600', 'text-white');
          b.classList.add('bg-slate-100', 'text-slate-600');
        });
        button.classList.remove('bg-slate-100', 'text-slate-600');
        button.classList.add('bg-blue-600', 'text-white');
        
        filterCards();
      });
    });
  </script>
</Layout>
