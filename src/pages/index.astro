---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SkillCard from '../components/SkillCard.astro';
import { getCollection } from 'astro:content';
import newsData from '../data/daily-news.json';

const base = (import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL.slice(0, -1) : import.meta.env.BASE_URL);
const skills = (await getCollection('skills')).slice(0, 3);
const articles = (await getCollection('articles')).slice(0, 3);

// 最新 5 条资讯
const latestNews = newsData
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 5);

const categoryColors: Record<string, string> = {
  '政策法规': 'bg-blue-100 text-blue-700',
  '司法动态': 'bg-purple-100 text-purple-700',
  '知识产权': 'bg-green-100 text-green-700',
  'AI 与数据合规': 'bg-orange-100 text-orange-700',
  '企业合规': 'bg-indigo-100 text-indigo-700',
  '法律科技': 'bg-teal-100 text-teal-700',
  '监管动态': 'bg-red-100 text-red-700',
  '其他': 'bg-gray-100 text-gray-700',
};
---

<Layout>
  <section class="bg-gradient-to-b from-surface to-white py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold text-primary">法律实务与 AI 技能库</h1>
      <p class="mt-4 text-lg text-secondary max-w-2xl mx-auto">
        一个面向法律从业者的工具导航、实务文章与 AI 工作流技能库。
      </p>
      <div class="flex flex-wrap justify-center gap-4 mt-8">
        <a href={`${base}/nav`} class="bg-primary text-white px-6 py-2.5 rounded-lg hover:bg-primary-light transition-colors">进入法律导航</a>
        <a href={`${base}/skills`} class="bg-white text-primary border border-primary px-6 py-2.5 rounded-lg hover:bg-surface transition-colors">查看 AI 技能</a>
        <a href={`${base}/articles`} class="bg-white text-primary border border-primary px-6 py-2.5 rounded-lg hover:bg-surface transition-colors">阅读法律文章</a>
        <a href={`${base}/news`} class="bg-white text-primary border border-primary px-6 py-2.5 rounded-lg hover:bg-surface transition-colors">查看每日资讯</a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <p class="text-secondary text-center max-w-3xl mx-auto">
      本站用于沉淀法律常用网站导航、法律实务文章和 AI 技能方法论，关注知识产权、合同风控、企业合规、人工智能与数据合规等方向。内容仅供学习、研究和实务参考，不构成正式法律意见。
    </p>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <h2 class="text-xl font-semibold text-primary mb-6">最近更新文章</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {articles.map(a => (
        <ArticleCard
          title={a.data.title}
          slug={a.data.slug}
          description={a.data.description}
          category={a.data.category}
          tags={a.data.tags}
          published={a.data.published}
        />
      ))}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <h2 class="text-xl font-semibold text-primary mb-6">精选 AI 技能</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {skills.map(s => (
        <SkillCard
          title={s.data.title}
          slug={s.data.slug}
          description={s.data.description}
          category={s.data.category}
          tags={s.data.tags}
          version={s.data.version}
          updated={s.data.updated}
        />
      ))}
    </div>
  </section>

  {latestNews.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <h2 class="text-xl font-semibold text-primary mb-6">每日资讯</h2>
      <div class="space-y-3">
        {latestNews.map(item => (
          <a
            href={item.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-start gap-3 p-4 bg-white border border-gray-200 rounded-lg hover:shadow-md transition-shadow group"
          >
            <span class={`text-xs px-2 py-0.5 rounded-full whitespace-nowrap mt-0.5 ${categoryColors[item.category] || 'bg-gray-100 text-gray-700'}`}>
              {item.category}
            </span>
            <div class="flex-1 min-w-0">
              <h3 class="text-sm font-medium text-gray-900 group-hover:text-primary transition-colors line-clamp-1">{item.title}</h3>
              <p class="text-xs text-gray-500 mt-1 line-clamp-1">{item.summary}</p>
            </div>
            <span class="text-xs text-gray-400 whitespace-nowrap">{item.date}</span>
          </a>
        ))}
      </div>
      <div class="mt-4 text-center">
        <a href={`${base}/news`} class="text-sm text-primary hover:underline">查看更多资讯 &rarr;</a>
      </div>
    </section>
  )}

  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12 text-center">
    <a href={`${base}/nav`} class="text-primary hover:underline">查看全部法律导航 &rarr;</a>
  </section>
</Layout>
